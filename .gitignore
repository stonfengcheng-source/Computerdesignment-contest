# 忽略 AI 模型权重文件 (太大了，不能传 Git)
backend/data/weights/
*.safetensors
*.bin
*.pt
*.pth
*.h5

# 忽略用户上传的视频和多媒体测试文件
backend/data/uploads/
*.mp4
*.avi
*.webm

# 忽略本地生成的 SQLite 数据库 (避免不同设备的库冲突)
backend/data/*.db
backend/data/*.sqlite3

# 忽略虚拟环境 (如果你还没忽略的话)
.venv/

# 忽略前端依赖包
node_modules/
frontend/node_modules/

# 忽略 AI 训练过程中的中间权重检查点
results/

.idea/